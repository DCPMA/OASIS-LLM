# OASIS-LLM environment variables.
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real keys.

# ── LLM providers (set at least one) ────────────────────────────────────
# OpenRouter aggregates many providers under one key. Free-tier limited
# to 1000 requests / day across all `:free` models; the harness tracks
# this in the `or_free_daily` table.
OPENROUTER_API_KEY=

# Direct provider keys (optional — used when a RunConfig pins a provider).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Langfuse tracing (optional) ─────────────────────────────────────────
# Wired into LiteLLM via callbacks. If keys are absent, Langfuse is
# silently disabled — no other config changes required.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Dashboard mode ──────────────────────────────────────────────────────
# Set to "1" for the public read-only viewer (hides write controls,
# disables run/edit/delete actions). Defaults to "0" (full desktop mode).
OASIS_LLM_READONLY=0
